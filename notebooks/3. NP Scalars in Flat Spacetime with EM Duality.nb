Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Fsph", "=", 
    RowBox[{"CTensor", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"0", 
          RowBox[{"-", "Er"}], 
          RowBox[{"-", "E\[Theta]"}], 
          RowBox[{"-", "E\[Phi]"}]},
         {"Er", "0", 
          RowBox[{"B\[Phi]", "/", 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "[", "]"}], "]"}]}], 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Sin", "[", 
             RowBox[{"\[Theta]", "[", "]"}], "]"}]}], "B\[Theta]"}]},
         {"E\[Theta]", 
          RowBox[{
           RowBox[{"-", "B\[Phi]"}], "/", 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "[", "]"}], "]"}]}], "0", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"R", "[", "]"}], "2"], 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "[", "]"}], "]"}], "Br"}]},
         {"E\[Phi]", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "[", "]"}], "]"}], "B\[Theta]"}], 
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"R", "[", "]"}], "2"]}], 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "[", "]"}], "]"}], "Br"}], "0"}
        }], "\[NoBreak]", ")"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "coords"}], ",", 
        RowBox[{"-", "coords"}]}], "}"}]}], "\[IndentingNewLine]", "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Gsph", "=", 
   RowBox[{"CTensor", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"0", 
         RowBox[{"-", "Br"}], 
         RowBox[{"-", "B\[Theta]"}], 
         RowBox[{"-", "B\[Phi]"}]},
        {"Br", "0", 
         RowBox[{
          RowBox[{"-", "E\[Phi]"}], "/", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "[", "]"}], "]"}]}], 
         RowBox[{
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "[", "]"}], "]"}], "E\[Theta]"}]},
        {"B\[Theta]", 
         RowBox[{"E\[Phi]", "/", 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "[", "]"}], "]"}]}], "0", 
         RowBox[{
          RowBox[{"-", 
           SuperscriptBox[
            RowBox[{"R", "[", "]"}], "2"]}], 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "[", "]"}], "]"}], "Er"}]},
        {"B\[Phi]", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "[", "]"}], "]"}]}], "E\[Theta]"}], 
         RowBox[{
          SuperscriptBox[
           RowBox[{"R", "[", "]"}], "2"], 
          RowBox[{"Sin", "[", 
           RowBox[{"\[Theta]", "[", "]"}], "]"}], "Er"}], "0"}
       }], "\[NoBreak]", ")"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "coords"}], ",", 
       RowBox[{"-", "coords"}]}], "}"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]}], "Input",
