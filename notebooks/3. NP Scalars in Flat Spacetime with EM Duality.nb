  3.976941619401268*^9, 3.9769416330359483`*^9}, {3.976961627625554*^9, 
  3.9769616358313437`*^9}},ExpressionUUID->"1338d8a5-a23f-4a61-ad1d-\
17e7d90c9d94"],

Cell[TextData[{
 "Cartesian coordinates transform to spherical coordinates ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["x\:0303", "\[Mu]"], "=", 
   RowBox[{"{", 
    RowBox[{"t", ",", "x", ",", "y", ",", "z"}], "}"}]}]],ExpressionUUID->
  "290a3090-0cae-4964-9dad-172170ebfdf6"],
 "as\n\t",
 Cell[BoxData[
  RowBox[{"t", "=", "t"}]],ExpressionUUID->
  "acc6bd9c-7888-46bf-960e-5ddee2bf76c6"],
 "\n\t",
 Cell[BoxData[
  RowBox[{"x", "=", 
   RowBox[{"R", " ", 
    RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
    RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}]],ExpressionUUID->
  "efa06611-c054-42d9-b2c3-d0350df15951"],
 "\n\t",
 Cell[BoxData[
  RowBox[{"x", "=", 
   RowBox[{"R", " ", 
    RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
    RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}]],ExpressionUUID->
  "df5f6bfe-d416-43f7-bfd5-1820c941137b"],
 "\n\t",
 Cell[BoxData[
  RowBox[{"z", "=", 
   RowBox[{"R", " ", 
    RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]],ExpressionUUID->
  "049ee4f6-f8f0-4772-ae78-d1df5b7cb396"],
 "\n\nwhere the infinitesimal displacements are\n\t",
 Cell[BoxData[
  RowBox[{"dt", "=", "dt"}]],ExpressionUUID->
  "9f20789c-8bcc-408f-aeb0-2d9d8d1880cf"],
 "\n\t",
 Cell[BoxData[
  RowBox[{"dR", "=", 
   RowBox[{
    RowBox[{
     FractionBox["x", "R"], "dx"}], "+", 
    RowBox[{
     FractionBox["y", "R"], "dy"}], "+", 
    RowBox[{
     FractionBox["z", "R"], "dz"}]}]}]],ExpressionUUID->
  "cdcb3b90-b3e0-42db-a1d9-ee8ad57448ec"],
 "\n\t",
 Cell[BoxData[
  RowBox[{"d\[Theta]", "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox["R", "2"], 
      SqrtBox[
       RowBox[{
        SuperscriptBox["R", "2"], "-", 
        SuperscriptBox["z", "2"]}]]}]], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"x", " ", "y", " ", "dx"}], "+", 
      RowBox[{"y", " ", "z", " ", "dy"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["R", "2"], "-", 
         SuperscriptBox["z", "2"]}], ")"}], "dz"}]}], ")"}]}]}]],
  ExpressionUUID->"9e79ef8a-ae2a-492f-ae42-6b0290a503b6"],
 "\n\t",
 Cell[BoxData[
  RowBox[{"d\[Phi]", "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox["R", "2"], "-", 
      SuperscriptBox["z", "2"]}]], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "y"}], " ", "dx"}], "+", 
      RowBox[{"x", " ", "dy"}]}], ")"}]}]}]],ExpressionUUID->
  "33f79b0e-cc03-4150-a80e-05e7286e8c3e"],
 "\n\t\nTo go from spherical (no tilde) to Cartesian (denoted with the \
tilde), we define the tensors\n\t",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    SuperscriptBox["s\:0303", "\[Mu]"], "\[Nu]"], "=", 
   FractionBox[
    RowBox[{"\[PartialD]", 
     SuperscriptBox["x", "\[Mu]"]}], 
    RowBox[{"\[PartialD]", 
     SuperscriptBox["x\:0303", "\[Nu]"]}]]}]],ExpressionUUID->
  "55d5c775-a5bd-44bf-b74d-f21135dee257"],
 "\n\t",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    SuperscriptBox["s", "\[Mu]"], "\[Nu]"], "=", 
   FractionBox[
    RowBox[{"\[PartialD]", 
     SuperscriptBox["x\:0303", "\[Mu]"]}], 
    RowBox[{"\[PartialD]", 
     SuperscriptBox["x", "\[Nu]"]}]]}]],ExpressionUUID->
  "4ff0995c-2894-4050-a09a-82739380e371"],
 "\n\nwhere\n\t",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    OverscriptBox["T", "~"], "\[Mu]\[Nu]"], "=", 
   RowBox[{
    SubscriptBox[
     SuperscriptBox["s\:0303", "\[Alpha]"], "\[Mu]"], 
    SubscriptBox[
     SuperscriptBox["s\:0303", "\[Beta]"], "\[Nu]"], 
    SubscriptBox["T", "\[Alpha]\[Beta]"]}]}]],ExpressionUUID->
  "0c3bd2dd-97c1-4b5c-9368-34b7fada0aae"],
 "\n\t",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    OverscriptBox["V", "~"], "\[Mu]"], "=", 
   RowBox[{
    SubscriptBox[
     SuperscriptBox["s\:0303", "\[Alpha]"], "\[Mu]"], 
    SubscriptBox["V", "\[Alpha]"]}]}]],ExpressionUUID->
  "4b5332c1-e51d-4437-b87f-712509b657f8"],
 "\n\t",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    OverscriptBox["V", "~"], "\[Mu]"], "=", 
   RowBox[{
    SubscriptBox[
     SuperscriptBox["s", "\[Mu]"], "\[Alpha]"], 
    SuperscriptBox["V", "\[Alpha]"]}]}]],ExpressionUUID->
  "85bf7234-ae8b-4591-9ebd-f973a7d34239"]
}], "Text",
 CellChangeTimes->{{3.959922443632317*^9, 3.959922595376515*^9}, {
   3.95992262823766*^9, 3.959922689349843*^9}, {3.959922763666229*^9, 
