Cell[BoxData[{
 RowBox[{
  RowBox[{"dR", "=", 
   RowBox[{
    RowBox[{
     FractionBox["x", 
      RowBox[{"R", "[", "]"}]], "dx"}], "+", 
    RowBox[{
     FractionBox["y", 
      RowBox[{"R", "[", "]"}]], "dy"}], "+", 
    RowBox[{
     FractionBox["z", 
      RowBox[{"R", "[", "]"}]], "dz"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Theta]", "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"R", "[", "]"}], "2"], 
      SqrtBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"R", "[", "]"}], "2"], "-", 
        SuperscriptBox["z", "2"]}]]}]], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"x", " ", "z", " ", "dx"}], " ", "+", " ", 
      RowBox[{"y", " ", "z", " ", "dy"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"R", "[", "]"}], "2"], "-", 
         SuperscriptBox["z", "2"]}], ")"}], "dz"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"d\[Phi]", "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"R", "[", "]"}], "2"], "-", 
       SuperscriptBox["z", "2"]}]], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "y"}], " ", "dx"}], "+", 
       RowBox[{"x", " ", "dy"}]}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dv", "=", 
   RowBox[{"{", 
    RowBox[{"dt", ",", "dR", ",", "d\[Theta]", ",", "d\[Phi]"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dv\:0303", "=", 
    RowBox[{"{", 
     RowBox[{"dt", ",", "dx", ",", "dy", ",", "dz"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"s\:0303", "=", 
    RowBox[{"CTensor", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Table", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[PartialD]", 
          RowBox[{"dv\:0303", "[", 
           RowBox[{"[", "j", "]"}], "]"}]], 
         RowBox[{"dv", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "4"}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "4"}], "}"}]}], "\[IndentingNewLine]", 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"coords", ",", 
        RowBox[{"-", "coords"}]}], "}"}]}], "\[IndentingNewLine]", "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s\:0303", "[", 
   RowBox[{"\[Mu]", ",", 
    RowBox[{"-", "\[Nu]"}]}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.959930137821996*^9, 3.959930252360324*^9}, {
   3.959930470658843*^9, 3.959930529063908*^9}, 3.959930589508541*^9, {
