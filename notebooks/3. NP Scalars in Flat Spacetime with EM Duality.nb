Cell["\<\
Computations in xCoba perform intermediate simplifications, using the \
function stored in $CVSimplify, specify it here.
Default is Simplify, FullSimplify can be used to further simplification, \
Expand should be faster and Identity even faster, at the cost of equation \
length.\
\>", "Text",
 CellChangeTimes->{{3.910261321506174*^9, 
  3.91026139553081*^9}},ExpressionUUID->"428365f1-cca1-4783-972d-\
3b160e084781"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$CVSimplify", " ", "=", " ", "Simplify"}], ";"}]], "Input",
 CellChangeTimes->{{3.91026134264785*^9, 3.910261352272637*^9}, 
   3.910261399007399*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"e9cede3d-fc41-42ee-be80-feae323e5267"]
}, Closed]],

