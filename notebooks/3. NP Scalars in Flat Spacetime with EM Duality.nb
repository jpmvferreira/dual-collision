Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"l", "=", 
    RowBox[{"CTensor", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       FractionBox["1", 
        SqrtBox["2"]], 
       RowBox[{"{", 
