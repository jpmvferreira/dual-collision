Cell["\<\
Create an auxiliary function to print the non-zero components of an arbitrary \
tensor in a single table. (adapted from: \
https://groups.google.com/g/xAct/c/l4P1p7R8wvU )\
\>", "Text",
 CellChangeTimes->{{3.909739171246963*^9, 3.90973917346376*^9}, {
  3.909739488058969*^9, 3.9097395389028*^9}, {3.909739844535282*^9, 
  3.909739858992926*^9}, {3.909746705796522*^9, 3.9097467136400223`*^9}, {
  3.910596397800083*^9, 
  3.910596401531012*^9}},ExpressionUUID->"a2e1f739-d65d-409d-867d-\
da157ecdc607"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CTensorEntries", "[", 
     RowBox[{"ctensor_CTensor", ",", 
      RowBox[{"T_", "?", "xTensorQ"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "assoc", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"ToTensorRules", "[", 
        RowBox[{"T", ",", "ctensor"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"frules", " ", "=", " ", 
        RowBox[{"Join", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"First", "[", 
            RowBox[{"TensorValues", "[", "T", "]"}], "]"}], "/.", 
           RowBox[{"Last", "[", 
            RowBox[{"TensorValues", "[", "T", "]"}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Last", "[", 
           RowBox[{"TensorValues", "[", "T", "]"}], "]"}]}], 
         "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"assoc", "=", "\[IndentingNewLine]", 
        RowBox[{"GroupBy", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"DeleteCases", "[", 
           RowBox[{"frules", ",", 
            RowBox[{"_", "->", "0"}]}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Last", "->", "First"}]}], "\[IndentingNewLine]", "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"Grid", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Reverse", "/@", 
          RowBox[{"List", "@@@", 
           RowBox[{"Normal", "[", 
            RowBox[{"Column", "/@", "assoc"}], "]"}]}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Frame", "->", 
          RowBox[{"{", 
           RowBox[{"False", ",", "All"}], "}"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Spacings", "->", 
          RowBox[{"{", 
           RowBox[{"2", ",", "1"}], "}"}]}]}], "\[IndentingNewLine]", 
        "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CTensorEntries", "[", 
   RowBox[{
    RowBox[{"ctensor", ":", 
     RowBox[{"CTensor", "[", 
      RowBox[{"array_", ",", "bases_", ",", "_"}], "]"}]}], ",", 
    RowBox[{"name_String", ":", "\"\<T\>\""}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"vbundles", ",", "indices", ",", "sym", ",", "T", ",", "res"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"vbundles", "=", 
      RowBox[{"VBundleOfBasis", "/@", "bases"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"indices", "=", 
      RowBox[{"NewIndexIn", "/@", "vbundles"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"sym", "=", 
      RowBox[{
       RowBox[{"TensorSymmetry", "[", "array", "]"}], "/.", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"cyc", ":", 
           RowBox[{"System`Cycles", "[", "cycs_", "]"}]}], ",", "sign_"}], 
         "}"}], ":>", 
        RowBox[{"Times", "[", 
         RowBox[{"sign", ",", 
          RowBox[{"Cycles", "@@", "cycs"}]}], "]"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"ListQ", "[", "sym", "]"}], ",", 
       RowBox[{"sym", "=", 
        RowBox[{"GenSet", "@@", "sym"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"$DefInfoQ", "=", "False"}], "}"}], ",", 
       RowBox[{"DefTensor", "[", 
        RowBox[{
         RowBox[{"T", "@@", "indices"}], ",", "vbundles", ",", "sym", ",", 
         RowBox[{"PrintAs", "->", "name"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"res", "=", 
      RowBox[{"CTensorEntries", "[", 
       RowBox[{"ctensor", ",", "T"}], "]"}]}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.909739541631949*^9, 3.909739543828134*^9}, 
   3.909739839872527*^9, {3.909746121790917*^9, 3.909746185445546*^9}, {
   3.909746263611516*^9, 3.909746275626602*^9}, {3.9097463652552767`*^9, 
   3.909746391303072*^9}, {3.9097464372866163`*^9, 3.909746477394536*^9}, 
   3.909828920363198*^9},
 CellLabel->"In[4]:=",ExpressionUUID->"b7e2c863-9759-494f-82b7-d12a8cfa701c"],

Cell["\<\
An auxiliary function that returns the independent entries of a given tensor. \
This is essentially a poorly-optimized modification of the function above.\
\>", "Text",
 CellChangeTimes->{{3.9103279637980537`*^9, 3.910327983539662*^9}, {
  3.910328210468519*^9, 3.91032825446313*^9}, {3.910328288529339*^9, 
  3.910328310361043*^9}, {3.91032837332158*^9, 3.9103284576095047`*^9}, {
  3.910359262384744*^9, 
  3.9103592739571047`*^9}},ExpressionUUID->"dd35a755-5ad8-4e40-8cd1-\
2c6ce0c4f827"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CTensorIndependent", "[", 
   RowBox[{"ctensor", ":", 
    RowBox[{"CTensor", "[", 
     RowBox[{"array_", ",", "bases_", ",", "_"}], "]"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"vbundles", ",", "indices", ",", "sym", ",", "T", ",", "res"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"vbundles", "=", 
      RowBox[{"VBundleOfBasis", "/@", "bases"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"indices", "=", 
      RowBox[{"NewIndexIn", "/@", "vbundles"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"sym", "=", 
      RowBox[{
       RowBox[{"TensorSymmetry", "[", "array", "]"}], "/.", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"cyc", ":", 
           RowBox[{"System`Cycles", "[", "cycs_", "]"}]}], ",", "sign_"}], 
         "}"}], ":>", 
        RowBox[{"Times", "[", 
         RowBox[{"sign", ",", 
          RowBox[{"Cycles", "@@", "cycs"}]}], "]"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"ListQ", "[", "sym", "]"}], ",", 
       RowBox[{"sym", "=", 
        RowBox[{"GenSet", "@@", "sym"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"$DefInfoQ", "=", "False"}], "}"}], ",", 
       RowBox[{"DefTensor", "[", 
        RowBox[{
         RowBox[{"T", "@@", "indices"}], ",", "vbundles", ",", "sym", ",", 
         RowBox[{"PrintAs", "->", "name"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ToTensorRules", "[", 
      RowBox[{"T", ",", "ctensor"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"frules", " ", "=", " ", 
      RowBox[{"Join", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"First", "[", 
          RowBox[{"TensorValues", "[", "T", "]"}], "]"}], "/.", 
         RowBox[{"Last", "[", 
          RowBox[{"TensorValues", "[", "T", "]"}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Last", "[", 
         RowBox[{"TensorValues", "[", "T", "]"}], "]"}]}], 
       "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"assoc", "=", "\[IndentingNewLine]", 
      RowBox[{"GroupBy", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"DeleteCases", "[", 
         RowBox[{"frules", ",", 
          RowBox[{"_", "->", "0"}]}], "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Last", "->", "First"}]}], "\[IndentingNewLine]", "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"Keys", "[", "assoc", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9103284683457623`*^9, 3.91032849265734*^9}, {
   3.910328641084442*^9, 3.910328641548217*^9}, {3.910328689107373*^9, 
