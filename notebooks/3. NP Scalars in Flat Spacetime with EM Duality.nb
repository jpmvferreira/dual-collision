 RowBox[{
  RowBox[{
   RowBox[{"F\:0303", "=", 
    RowBox[{"CTensor", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"0", 
