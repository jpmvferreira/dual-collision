Cell[BoxData[{
 RowBox[{
  RowBox[{"v\:0303", "=", 
   RowBox[{"{", 
    RowBox[{"t", ",", 
     RowBox[{
      RowBox[{"R", "[", "]"}], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Theta]", "[", "]"}], "]"}], 
      RowBox[{"Cos", "[", 
       RowBox[{"\[Phi]", "[", "]"}], "]"}]}], ",", 
     RowBox[{
      RowBox[{"R", "[", "]"}], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Theta]", "[", "]"}], "]"}], 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Phi]", "[", "]"}], "]"}]}], ",", 
     RowBox[{
      RowBox[{"R", "[", "]"}], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"\[Theta]", "[", "]"}], "]"}]}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"v", "=", 
    RowBox[{"{", 
     RowBox[{"t", ",", 
      RowBox[{"R", "[", "]"}], ",", 
      RowBox[{"\[Theta]", "[", "]"}], ",", 
      RowBox[{"\[Phi]", "[", "]"}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"s", "=", 
    RowBox[{"CTensor", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Table", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[PartialD]", 
          RowBox[{"v", "[", 
           RowBox[{"[", "i", "]"}], "]"}]], 
         RowBox[{"v\:0303", "[", 
          RowBox[{"[", "j", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "4"}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "4"}], "}"}]}], "\[IndentingNewLine]", 
       "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"coords", ",", 
        RowBox[{"-", "coords"}]}], "}"}]}], "\[IndentingNewLine]", "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s", "[", 
   RowBox[{"\[Mu]", ",", 
    RowBox[{"-", "\[Nu]"}]}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9598485401962967`*^9, 3.959848697464184*^9}, {
