Cell["\<\
Define and set the 4-metric for the Dyonic Kerr-Newman in (spherical) \
quasi-isotropic coordinates, as obtained in the previous notebook\
\>", "Text",
 CellChangeTimes->{{3.959919911201958*^9, 3.959919932410404*^9}, {
  3.959920143088917*^9, 3.95992016425863*^9}, {3.959920270085164*^9, 
