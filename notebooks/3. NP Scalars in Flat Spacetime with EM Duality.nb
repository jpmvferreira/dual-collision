Cell[TextData[{
 "3. Compute ",
 Cell[BoxData[
  SubscriptBox["F", "\[Mu]\[Nu]"]],ExpressionUUID->
  "6458c321-1f24-4a38-bcc0-9743d00a3416"],
 " and ",
 Cell[BoxData[
  SubscriptBox["G", "\[Mu]\[Nu]"]],
  FormatType->StandardForm,ExpressionUUID->
  "4f024447-655c-47ab-ac3f-4ecd83ff9fbd"],
 " in spherical coordinates"
}], "Section",
 CellChangeTimes->{{3.959847647636464*^9, 3.9598476680867023`*^9}, {
  3.959849382098957*^9, 3.959849382184005*^9}, {3.959920397181218*^9, 
