           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"z", "+", "z0"}], ")"}], "2"]}]]}]]}], ")"}], "2"], "-", 
    
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        SqrtBox[
         RowBox[{
          SuperscriptBox["Q1", "2"], "+", 
          SuperscriptBox["P1", "2"]}]], 
        RowBox[{"2", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["d", "2"], "+", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"z", "-", "z0"}], ")"}], "2"]}]]}]], "+", 
       FractionBox[
        SqrtBox[
         RowBox[{
          SuperscriptBox["Q2", "2"], "+", 
          SuperscriptBox["P2", "2"]}]], 
        RowBox[{"2", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["d", "2"], "+", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"z", "+", "z0"}], ")"}], "2"]}]]}]]}], ")"}], "2"]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.971517362754543*^9, 3.9715173961961193`*^9}, {
