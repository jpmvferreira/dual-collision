            RowBox[{"(", 
             RowBox[{"z", "+", "z0"}], ")"}], "2"]}]]}], "+", 
        RowBox[{
         SuperscriptBox["d", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", 
            SuperscriptBox["z", "2"]}], "+", 
           RowBox[{"2", " ", 
            SuperscriptBox["z0", "2"]}], "+", 
           RowBox[{
            SqrtBox[
             RowBox[{
              SuperscriptBox["d", "2"], "+", 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{"z", "-", "z0"}], ")"}], "2"]}]], " ", 
            SqrtBox[
             RowBox[{
              SuperscriptBox["d", "2"], "+", 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{"z", "+", "z0"}], ")"}], "2"]}]]}]}], ")"}]}], "+", 
        RowBox[{
         SuperscriptBox["z", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"6", " ", 
            SuperscriptBox["z0", "2"]}], "+", 
           RowBox[{
            SqrtBox[
             RowBox[{
              SuperscriptBox["d", "2"], "+", 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{"z", "-", "z0"}], ")"}], "2"]}]], " ", 
            SqrtBox[
             RowBox[{
              SuperscriptBox["d", "2"], "+", 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{"z", "+", "z0"}], ")"}], "2"]}]]}]}], ")"}]}]}], 
       ")"}]}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["d", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "-", "z0"}], ")"}], "2"]}], ")"}], "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["d", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "+", "z0"}], ")"}], "2"]}], ")"}], "2"]}], ")"}]}], 
   ")"}]}]], "Output",
 CellChangeTimes->{3.971517820140181*^9, 3.971517967373109*^9, 
