Cell[BoxData[
 RowBox[{"-", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"4", " ", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["P", "2"], "+", 
        SuperscriptBox["Q", "2"]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["d", "4"], "+", 
        SuperscriptBox["z", "4"], "+", 
        SuperscriptBox["z0", "4"], "-", 
