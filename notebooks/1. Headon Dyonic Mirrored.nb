Cell[TextData[{
 "Guessing that ",
 Cell[BoxData["\[Psi]"],
  FormatType->StandardForm,ExpressionUUID->
  "5b8c2384-fad6-43bb-a689-19789ee21de1"],
 " can be give by (always true since ",
 Cell[BoxData[
  RowBox[{"\[Psi]", ">", "0"}]],
  FormatType->StandardForm,ExpressionUUID->
  "10f4c335-4582-448d-8df0-767248e043e0"],
 " and inspired by solution in dyonic case)"
}], "Text",
