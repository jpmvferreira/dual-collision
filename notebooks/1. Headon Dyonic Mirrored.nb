      RowBox[{
       RowBox[{"(", 
        RowBox[{"r", "-", "z0"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"r", "+", "z0"}], ")"}], " ", 
       SubscriptBox["r", "-"], " ", 
       SubscriptBox["r", "+"]}]}], ")"}]}], 
   RowBox[{
    SuperscriptBox["\[Psi]", "3"], " ", 
    SubsuperscriptBox["r", "-", "4"], " ", 
    SubsuperscriptBox["r", "+", "4"]}]]}]], "Output",
 CellChangeTimes->{{3.9713320748842688`*^9, 3.971332083700067*^9}, 
