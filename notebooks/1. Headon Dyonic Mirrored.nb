  3.971517633894712*^9, 
  3.971517667399108*^9}},ExpressionUUID->"c151e94e-a881-48ab-a1da-\
f5ac212ba413"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Psi]", "[", 
   RowBox[{"d_", ",", "z_"}], "]"}], ":=", 
  SqrtBox[
   RowBox[{"\[Phi]", "[", 
    RowBox[{"d", ",", "z"}], "]"}]]}]], "Input",
 CellChangeTimes->{{3.97151741967878*^9, 3.971517441482325*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"42b7924c-def1-476a-8914-d3d1f22f074f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Format", "[", "\[IndentingNewLine]", 
   RowBox[{"\[Phi]", "[", 
    RowBox[{"d", ",", "z"}], "]"}], "\[IndentingNewLine]", "]"}], ":=", 
  "\"\<\[Phi]\>\""}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Format", "[", "\[IndentingNewLine]", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"\[Phi]", "[", 
      RowBox[{"d", ",", "z"}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"d", ",", "n_"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"z", ",", "m_"}], "}"}]}], "\[IndentingNewLine]", "]"}], 
   "\[IndentingNewLine]", "]"}], ":=", 
  RowBox[{
   SuperscriptBox["\"\<\!\(\*SubscriptBox[\(\[PartialD]\), \(d\)]\)\>\"", 
    "n"], 
   SuperscriptBox["\"\<\!\(\*SubscriptBox[\(\[PartialD]\), \(z\)]\)\>\"", 
    "m"], 
   RowBox[{"HoldForm", "[", "\"\<\[Phi]\>\"", "]"}]}]}]}], "Input",
 CellLabel->"In[11]:=",ExpressionUUID->"9bc0226d-e175-4a1c-800f-480e3f957392"],

Cell[TextData[{
 "where ",
 Cell[BoxData["d"],
  FormatType->StandardForm,ExpressionUUID->
  "3056508c-2b33-43c9-8341-b75263b790a9"],
 " is cylindrical radius, and moving ",
 Cell[BoxData[
  SuperscriptBox["\[Psi]", "3"]],
  FormatType->StandardForm,ExpressionUUID->
  "e3f1ef86-fb97-4a6e-a83f-9bacc45b3d08"],
 " from a division in the rhs to the lhs, the lhs is"
}], "Text",
 CellChangeTimes->{{3.9715174827007427`*^9, 3.971517547543715*^9}, {
  3.971517617195065*^9, 
  3.9715176208211412`*^9}},ExpressionUUID->"1c1f2437-729a-4131-bff0-\
13114a2a17ef"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lhs", "=", 
  RowBox[{
   RowBox[{"8", 
    SuperscriptBox[
     RowBox[{"\[Psi]", "[", 
      RowBox[{"d", ",", "z"}], "]"}], "3"], 
    RowBox[{"Laplacian", "[", 
     RowBox[{
      RowBox[{"\[Psi]", "[", 
       RowBox[{"d", ",", "z"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"d", ",", "\[CurlyPhi]", ",", "z"}], "}"}], ",", 
      "\"\<Cylindrical\>\""}], "]"}]}], "//", "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.971517512856001*^9, 3.971517532609377*^9}, {
   3.971517568175171*^9, 3.971517571072112*^9}, {3.971517718501141*^9, 
