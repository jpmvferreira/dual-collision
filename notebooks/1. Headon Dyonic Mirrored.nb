          TagBox["\<\"\[Phi]\"\>",
           HoldForm]}], "+", 
         RowBox[{
          
          SuperscriptBox["\<\"\\!\\(\\*SubscriptBox[\\(\[PartialD]\\), \
\\(d\\)]\\)\"\>", "2"], " ", 
          TagBox["\<\"\[Phi]\"\>",
           HoldForm]}]}], ")"}]}]}], ")"}]}], "d"]}]], "Output",
 CellChangeTimes->{{3.97151755032299*^9, 3.971517571605172*^9}, 
