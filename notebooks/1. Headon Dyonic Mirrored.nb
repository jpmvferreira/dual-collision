 CellLabel->"In[13]:=",ExpressionUUID->"f5b0eb12-18b2-4a80-8eaa-19eb9e526376"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", "2"}], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"\<\"\\!\\(\\*SubscriptBox[\\(\[PartialD]\\), \\(z\\)]\\)\"\>", 
      " ", 
      TagBox["\<\"\[Phi]\"\>",
       HoldForm]}], ")"}], "2"]}], "-", 
  RowBox[{"2", " ", 
   SuperscriptBox[
    RowBox[{"(", 
