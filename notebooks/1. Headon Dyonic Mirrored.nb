 CellLabel->"Out[13]=",ExpressionUUID->"4f603f35-631c-4619-9dd4-222778b26353"]
}, Open  ]],

Cell[TextData[{
 "Guessing that the solution is (taking ",
 Cell[BoxData[
  SubscriptBox["z", "0"]],
  FormatType->StandardForm,ExpressionUUID->
  "7d7519b3-6e3e-4aa6-9a7f-4118a56df74a"],
 " to be zero falls back to the solution for the dyonic case, with 2M, 2Q and \
2P)"
}], "Text",
 CellChangeTimes->{{3.9715176273761473`*^9, 3.9715176300106077`*^9}, {
  3.971517671814489*^9, 
  3.9715177007137213`*^9}},ExpressionUUID->"4cfa83b1-a957-43d0-9421-\
33e1c2f473e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[Phi]", "[", 
    RowBox[{"d_", ",", "z_"}], "]"}], ":=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "+", 
       FractionBox["M", 
        RowBox[{"2", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["d", "2"], "+", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"z", "-", "z0"}], ")"}], "2"]}]]}]], "+", 
       FractionBox["M", 
        RowBox[{"2", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["d", "2"], "+", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"z", "+", "z0"}], ")"}], "2"]}]]}]]}], ")"}], "2"], "-", 
    
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        SqrtBox[
         RowBox[{
          SuperscriptBox["Q", "2"], "+", 
          SuperscriptBox["P", "2"]}]], 
        RowBox[{"2", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["d", "2"], "+", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"z", "-", "z0"}], ")"}], "2"]}]]}]], "+", 
       FractionBox[
        SqrtBox[
         RowBox[{
          SuperscriptBox["Q", "2"], "+", 
          SuperscriptBox["P", "2"]}]], 
        RowBox[{"2", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["d", "2"], "+", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"z", "+", "z0"}], ")"}], "2"]}]]}]]}], ")"}], "2"]}]}], 
  ";"}]], "Input",
