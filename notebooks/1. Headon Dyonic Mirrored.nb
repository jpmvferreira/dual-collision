Cell[BoxData[{
 RowBox[{
  RowBox[{"Ei", "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{
       SuperscriptBox["\[Psi]", 
        RowBox[{"-", "6"}]], "Q"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "-", "z0"}], ")"}], "2"]}], ")"}], 
       RowBox[{"3", "/", "2"}]]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", 
       RowBox[{"z", "-", "z0"}]}], "}"}]}], "+", 
    RowBox[{
     FractionBox[
      RowBox[{
       SuperscriptBox["\[Psi]", 
        RowBox[{"-", "6"}]], "Q"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "+", "z0"}], ")"}], "2"]}], ")"}], 
       RowBox[{"3", "/", "2"}]]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", 
       RowBox[{"z", "+", "z0"}]}], "}"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Bi", "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{
       SuperscriptBox["\[Psi]", 
        RowBox[{"-", "6"}]], "P"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "-", "z0"}], ")"}], "2"]}], ")"}], 
       RowBox[{"3", "/", "2"}]]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", 
       RowBox[{"z", "-", "z0"}]}], "}"}]}], "+", 
    RowBox[{
     FractionBox[
      RowBox[{
       SuperscriptBox["\[Psi]", 
        RowBox[{"-", "6"}]], "P"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"z", "+", "z0"}], ")"}], "2"]}], ")"}], 
